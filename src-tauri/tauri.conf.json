{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ACC Pitwall",
  "version": "1.0.0",
  "identifier": "com.acc.config-generator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ACC Pitwall",
        "width": 1400,
        "height": 900,
        "devtools": true,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "resources": [
      "../acc-server.zip"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
